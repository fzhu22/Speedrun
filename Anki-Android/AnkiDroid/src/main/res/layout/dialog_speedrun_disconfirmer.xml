<!-- Speedrun: in-review disconfirmer prompt. Shows the missed card's question and answer so the
     learner can look at it while writing their disconfirmer, then a multi-line input. Scrolls so
     it stays usable on small screens with the keyboard up. Keeps the dialog_text_input_layout /
     dialog_text_input ids so the shared AlertDialog.input() helper drives validation + keyboard. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/speedrun_disconfirmer_intro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:id="@+id/speedrun_disconfirmer_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/speedrun_disconfirmer_card_bg"
            android:lineSpacingExtra="2dp"
            android:padding="12dp"
            android:textIsSelectable="true"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/dialog_text_input_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dialog_text_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="6"
                android:minLines="3" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</ScrollView>
